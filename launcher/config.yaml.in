# ExaGO Launcher Configuration
# Edit these paths when deploying on a different machine

# Root ExaGO directory
exago_dir: @LAUNCH_EXAGO_DIR@

# Path to compiled application binaries
applications_dir: @LAUNCH_BIN_DIR@

# Path to data files (network files, contingencies, scenarios, load profiles)
datafiles_dir: @LAUNCH_EXAGO_DIR@/datafiles

# Path to visualization directory
viz_dir: @LAUNCH_EXAGO_DIR@/viz

# Path to GIC data files
gic_data_dir: @LAUNCH_EXAGO_DIR@/viz/data

# Directory for simulation output files
output_dir: @LAUNCH_EXAGO_DIR@/../LLMSim/launcher/output

# Environment variables needed at runtime
environment:
  ld_library_path:
    - @IPOPT_ROOT_DIR@/lib
  path:
    - @PETSC_DIR@/bin
  pythonpath:
    - @LAUNCH_EXAGO_PYTHON_PATH@
