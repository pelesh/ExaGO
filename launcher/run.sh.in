#!/bin/bash
# ExaGO Launcher - Streamlit Application
# Optional: activate conda environment
# conda activate exago312

readonly _launcher_dir=@LAUNCH_EXAGO_LAUNCHER_DIR@
readonly _streamlit_cmd=@LAUNCH_EXAGO_STREAMLIT_CMD@

${_streamlit_cmd} ${_launcher_dir}/app.py -- --config ${_launcher_dir}/config.yaml
